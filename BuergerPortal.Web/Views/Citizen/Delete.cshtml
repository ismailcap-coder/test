@model BuergerPortal.Web.ViewModels.CitizenViewModel
@{
    ViewBag.Title = "Delete Citizen";
}

<h2>Delete Citizen</h2>

<h3>Are you sure you want to delete this citizen?</h3>

<div class="detail-card">
    <table class="detail-table">
        <tr>
            <td><strong>Name</strong></td>
            <td>@Model.FullName</td>
        </tr>
        <tr>
            <td><strong>Tax ID</strong></td>
            <td>@Model.TaxId</td>
        </tr>
        <tr>
            <td><strong>City</strong></td>
            <td>@Model.City</td>
        </tr>
        <tr>
            <td><strong>Registration Date</strong></td>
            <td>@Model.RegistrationDate.ToShortDateString()</td>
        </tr>
    </table>
</div>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    <div class="form-actions">
        <input type="submit" value="Delete" class="btn btn-danger" />
        @Html.ActionLink("Cancel", "Index", null, new { @class = "btn" })
    </div>
}
