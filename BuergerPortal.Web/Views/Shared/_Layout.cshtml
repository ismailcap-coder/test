<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>@ViewBag.Title - BuergerPortal</title>
    <link rel="stylesheet" href="~/Content/Site.css" />
</head>
<body>
    <div id="header">
        <h1>BuergerPortal</h1>
        <p class="subtitle">Citizen Services Management for German Public Offices</p>
        <nav>
            <ul>
                <li>@Html.ActionLink("Dashboard", "Index", "Home")</li>
                <li>@Html.ActionLink("Citizens", "Index", "Citizen")</li>
                <li>@Html.ActionLink("Applications", "Index", "Application")</li>
                <li>@Html.ActionLink("Reports", "Dashboard", "Report")</li>
                <li>@Html.ActionLink("About", "About", "Home")</li>
            </ul>
        </nav>
    </div>

    <div id="main-content">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-error">@TempData["ErrorMessage"]</div>
        }
        @RenderBody()
    </div>

    <div id="footer">
        <p>&copy; @DateTime.Now.Year - BuergerPortal | Powered by ASP.NET Core MVC</p>
    </div>

    <script src="~/Scripts/jquery-3.7.1.min.js"></script>
    <script src="~/Scripts/jquery.validate.min.js"></script>
    <script src="~/Scripts/jquery.validate.unobtrusive.min.js"></script>
    @RenderSection("scripts", required: false)
</body>
</html>
